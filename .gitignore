__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.so

# Virtual envs
.venv/
venv/
env/
ENV/
.env
.env.local
.env.*.local

# uv / poetry
.uv-cache/
poetry.lock.bak

# Testing
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
.hypothesis/

